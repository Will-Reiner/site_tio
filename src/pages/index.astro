---
import { getCollection, render } from "astro:content";
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import Citacao from "../components/Citacao.astro";
import MidiaCard from "../components/MidiaCard.astro";
import CanalCard from "../components/CanalCard.astro";
import FaixaCta from "../components/FaixaCta.astro";
import CabecalhoSecao from "../components/CabecalhoSecao.astro";
import FotoEditorial from "../components/FotoEditorial.astro";
import Botao from "../components/Botao.astro";
import Icon from "../components/Icon.astro";
import Divisor from "../components/Divisor.astro";

import { SOBRE_HOME, CITACAO, FRASES_MARQUEE, VIDEO_APRESENTACAO } from "../data/conteudo.ts";
import { CANAIS_YOUTUBE } from "../data/site.ts";
import { IMPRENSA } from "../data/imprensa.ts";
import entrevista from "../assets/eduardo-entrevista.jpeg";
import audiencia from "../assets/eduardo-audiencia.jpeg";

const propostas = (await getCollection("propostas")).sort(
  (a, b) => a.data.ordem - b.data.ordem,
);
const eixos = await Promise.all(
  propostas.map(async (p) => {
    const { Content } = await render(p);
    return { ...p, Content };
  }),
);
// Cor do topo/número de cada card de luta (hex inline vence o border-tinta).
const acentoLuta: Record<string, { hex: string; num: string; chip: string }> = {
  rosa: { hex: "#0b6b4b", num: "text-rosa", chip: "bg-rosa text-creme" },
  azul: { hex: "#0b57a4", num: "text-azul", chip: "bg-azul text-creme" },
  ambar: { hex: "#3d6b45", num: "text-ambar-escuro", chip: "bg-ambar-escuro text-creme" },
  tinta: { hex: "#0a2540", num: "text-tinta", chip: "bg-tinta text-creme" },
};
const featured = IMPRENSA.find((i) => i.destaque) ?? IMPRENSA[0];
---

<Base>
  <Hero />

  <Marquee itens={FRASES_MARQUEE} variante="rosa" />

  <!-- Vídeo de apresentação -->
  <section class="mx-auto max-w-4xl px-5 pt-16 pb-20 lg:px-8 lg:pt-24 lg:pb-24">
    <CabecalhoSecao
      kicker="Em vídeo"
      titulo="Conheça minhas lutas"
      alinhamento="centro"
      class="mx-auto max-w-2xl"
    />
    <div class="mt-10 overflow-hidden rounded-3xl border-2 border-tinta shadow-zine">
      {
        VIDEO_APRESENTACAO.id ? (
          <iframe
            class="aspect-video w-full"
            src={`https://www.youtube-nocookie.com/embed/${VIDEO_APRESENTACAO.id}`}
            title={VIDEO_APRESENTACAO.titulo}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        ) : (
          // TODO (vídeo): assim que o vídeo estiver pronto, cole o ID do
          // YouTube em VIDEO_APRESENTACAO (src/data/conteudo.ts) — este espaço
          // reservado é substituído automaticamente pelo player.
          <div class="fundo-azul-degrade relative grid aspect-video place-items-center text-center text-creme">
            <div
              class="halftone pointer-events-none absolute inset-0 opacity-20"
              aria-hidden="true"
            />
            <div class="relative px-6">
              <span class="mx-auto grid h-16 w-16 place-items-center rounded-full bg-rosa text-creme shadow-zine">
                <Icon name="play" size={28} />
              </span>
              <p class="mt-4 font-display text-sm font-bold uppercase tracking-[0.2em] text-creme/70">
                Vídeo em breve
              </p>
            </div>
          </div>
        )
      }
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <Divisor />
  </div>

  <!-- Quem sou eu -->
  <section class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-24">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <CabecalhoSecao kicker="Quem sou eu" titulo="Do chão da fiscalização para o Congresso" />
        <div class="mt-6 space-y-4 text-lg leading-relaxed text-tinta/80">
          {SOBRE_HOME.map((p) => <p>{p}</p>)}
        </div>
        <div class="mt-8">
          <Botao href="/minha-historia/" variante="rosa" tamanho="md" iconeFim="seta-direita">
            Minha história completa
          </Botao>
        </div>
      </div>
      <div class="order-first lg:order-last">
        <FotoEditorial
          src={audiencia}
          alt="Eduardo Reiner em audiência pública, ao lado de autoridades"
          cor="azul"
          rotacao={-2}
          aspecto="4 / 3"
          class="mx-auto"
        />
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <Divisor />
  </div>

  <!-- Lutas -->
  <section class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-24">
    <CabecalhoSecao
      kicker="No que eu acredito"
      titulo="As ideias que guiam esta caminhada"
      class="max-w-2xl"
    />
    <p class="mt-3 max-w-2xl text-tinta/70">
      Toque em cada bandeira para ler o que eu penso, direto ao ponto.
    </p>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        eixos.map((p) => {
          const c = acentoLuta[p.data.cor] ?? acentoLuta.rosa;
          const num = String(p.data.ordem).padStart(2, "0");
          return (
            <button
              type="button"
              data-abrir-modal={`luta-${p.id}`}
              style={`border-top-color:${c.hex}`}
              class="btn-press group flex flex-col rounded-3xl border-2 border-t-8 border-tinta bg-creme p-6 text-left hover:-translate-y-1 hover:shadow-zine"
            >
              <span
                class:list={[
                  "num-tabular font-display text-4xl font-extrabold leading-none",
                  c.num,
                ]}
              >
                {num}
              </span>
              <h3 class="mt-4 text-xl font-bold leading-tight">{p.data.titulo}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-tinta/75">
                {p.data.resumo}
              </p>
              <span class="mt-4 inline-flex items-center gap-2 font-display text-sm font-bold text-azul-escuro">
                Ler mais
                <Icon
                  name="seta-direita"
                  size={15}
                  class="transition-transform group-hover:translate-x-1"
                />
              </span>
            </button>
          );
        })
      }
    </div>
  </section>

  <!-- Pop-ups das lutas -->
  {
    eixos.map((p) => {
      const c = acentoLuta[p.data.cor] ?? acentoLuta.rosa;
      const num = String(p.data.ordem).padStart(2, "0");
      const Conteudo = p.Content;
      return (
        <dialog id={`luta-${p.id}`} aria-labelledby={`luta-${p.id}-titulo`}>
          <div class="w-[min(92vw,34rem)] rounded-3xl border-2 border-tinta bg-creme p-6 shadow-zine sm:p-8">
            <div class="flex items-start justify-between gap-4">
              <span
                class:list={[
                  "grid h-11 w-11 place-items-center rounded-full font-display text-lg font-extrabold",
                  c.chip,
                ]}
              >
                {num}
              </span>
              <button
                type="button"
                data-fechar-modal
                aria-label="Fechar"
                class="btn-press grid h-9 w-9 shrink-0 place-items-center rounded-full border-2 border-tinta text-tinta"
              >
                ✕
              </button>
            </div>
            <h3
              id={`luta-${p.id}-titulo`}
              class="mt-4 text-2xl font-bold leading-tight sm:text-3xl"
            >
              {p.data.titulo}
            </h3>
            <div class="conteudo-md mt-4">
              <Conteudo />
            </div>
          </div>
        </dialog>
      );
    })
  }

  <!-- Citação -->
  <section class="fundo-azul-degrade relative overflow-hidden py-20 sm:py-24">
    <div
      class="pontos pointer-events-none absolute inset-0 text-creme/5"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-7xl px-5 lg:px-8">
      <Citacao
        texto={CITACAO.texto}
        autor={CITACAO.autor}
        cargo="Auditor fiscal do trabalho · Pré-candidato a deputado federal"
        variante="escuro"
      />
    </div>
  </section>

  <!-- Na mídia (prévia) -->
  <section class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-24">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <CabecalhoSecao kicker="Na mídia" titulo="Onde o trabalho vira pauta" />
      <Botao href="/na-midia/" variante="contorno" tamanho="md" iconeFim="seta-direita">
        Ver tudo
      </Botao>
    </div>
    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      {
        featured && (
          <MidiaCard
            titulo={featured.titulo}
            veiculo={featured.veiculo}
            data={featured.data}
            url={featured.url}
            resumo={featured.resumo}
            imagem={entrevista}
            destaque={false}
          />
        )
      }
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-1">
        {
          CANAIS_YOUTUBE.map((c) => (
            <CanalCard
              nome={c.nome}
              descricao={c.descricao}
              handle={c.handle}
              href={c.href}
            />
          ))
        }
      </div>
    </div>
  </section>

  <FaixaCta />
</Base>

<script>
  // Abre/fecha os pop-ups nativos (<dialog>) das lutas.
  document
    .querySelectorAll<HTMLButtonElement>("[data-abrir-modal]")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-abrir-modal");
        const dlg = id
          ? (document.getElementById(id) as HTMLDialogElement | null)
          : null;
        dlg?.showModal();
      });
    });
  document
    .querySelectorAll<HTMLButtonElement>("[data-fechar-modal]")
    .forEach((b) => b.addEventListener("click", () => b.closest("dialog")?.close()));
  document.querySelectorAll("dialog").forEach((dlg) => {
    dlg.addEventListener("click", (e) => {
      if (e.target === dlg) (dlg as HTMLDialogElement).close();
    });
  });
</script>
