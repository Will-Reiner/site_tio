---
import Base from "../layouts/Base.astro";
import Botao from "../components/Botao.astro";
---

<Base title="Página não encontrada" noindex={true}>
  <section
    class="mx-auto flex max-w-3xl flex-col items-center px-5 py-28 text-center lg:py-36"
  >
    <p class="font-display text-7xl font-extrabold leading-none text-rosa sm:text-9xl">
      404
    </p>
    <h1 class="mt-5 text-4xl font-bold leading-tight sm:text-5xl">
      Essa página saiu para o batente
    </h1>
    <p class="mt-4 max-w-md text-lg text-tinta/70">
      Não encontramos o que você procura. Que tal voltar para o começo da
      caminhada?
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Botao href="/" variante="rosa" tamanho="lg" iconeFim="seta-direita">
        Voltar ao início
      </Botao>
      <Botao href="/lutas/" variante="contorno" tamanho="lg">
        Ver lutas
      </Botao>
    </div>
  </section>
</Base>
