---
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import Base from "../../layouts/Base.astro";
import Botao from "../../components/Botao.astro";
import FaixaCta from "../../components/FaixaCta.astro";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog", ({ data }) => !data.rascunho);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) =>
  new Intl.DateTimeFormat("pt-BR", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  }).format(d);
---

<Base title={post.data.titulo} description={post.data.resumo}>
  <article class="mx-auto max-w-3xl px-5 py-16 lg:py-24">
    <a
      href="/na-midia/"
      class="font-display text-sm font-bold uppercase tracking-wide text-rosa hover:underline"
    >
      ← Na mídia
    </a>
    <p
      class="mt-6 font-display text-sm font-bold uppercase tracking-wide text-tinta/50"
    >
      {fmt(post.data.data)} · {post.data.autor}
    </p>
    <h1 class="mt-3 text-4xl font-extrabold leading-tight sm:text-5xl">
      {post.data.titulo}
    </h1>
    <p class="mt-5 text-xl leading-relaxed text-tinta/80">
      {post.data.resumo}
    </p>
    <hr class="my-8 border-tinta/15" />
    <div class="conteudo-md">
      <Content />
    </div>
    <div class="mt-12">
      <Botao href="/na-midia/" variante="contorno" tamanho="md"
        >Ver mais conteúdos</Botao
      >
    </div>
  </article>

  <FaixaCta />
</Base>
