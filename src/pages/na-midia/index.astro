---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import MidiaCard from "../../components/MidiaCard.astro";
import Redes from "../../components/Redes.astro";
import FotoEditorial from "../../components/FotoEditorial.astro";
import Divisor from "../../components/Divisor.astro";
import FaixaCta from "../../components/FaixaCta.astro";
import Icon from "../../components/Icon.astro";
import { IMPRENSA } from "../../data/imprensa.ts";
import entrevista from "../../assets/eduardo-entrevista.jpeg";
import artePopart from "../../assets/eduardo-arte-popart.jpeg";

const imgMap: Record<string, ImageMetadata> = { entrevista };
const posts = (
  await getCollection("blog", ({ data }) => !data.rascunho)
).sort((a, b) => b.data.data.getTime() - a.data.data.getTime());
const fmt = (d: Date) =>
  new Intl.DateTimeFormat("pt-BR", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  }).format(d);
---

<Base
  title="Na Mídia"
  description="Meus vídeos, entrevistas e artigos sobre trabalho, direitos e o futuro do Brasil — e minhas redes sociais."
>
  <h1 class="sr-only">Na mídia</h1>

  <!-- Reportagens, artigos e materiais -->
  <section class="mx-auto max-w-7xl px-5 py-16 lg:px-8 lg:py-24">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        IMPRENSA.map((m) => (
          <MidiaCard
            titulo={m.titulo}
            veiculo={m.veiculo}
            data={m.data}
            url={m.url}
            resumo={m.resumo}
            imagem={m.imagem ? imgMap[m.imagem] : undefined}
          />
        ))
      }
      {
        posts.map((post) => (
          <a
            href={`/na-midia/${post.id}/`}
            class="group flex flex-col rounded-3xl border-2 border-tinta bg-creme p-7 transition duration-200 hover:-translate-y-1 hover:shadow-zine"
          >
            <span class="font-display text-xs font-bold uppercase tracking-wide text-rosa">
              {fmt(post.data.data)}
            </span>
            <h2 class="mt-3 text-xl font-bold leading-tight">
              {post.data.titulo}
            </h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-tinta/75">
              {post.data.resumo}
            </p>
            <span class="mt-5 inline-flex items-center gap-2 font-display text-sm font-bold transition-colors group-hover:text-rosa">
              Ler artigo
              <Icon
                name="seta-direita"
                size={16}
                class="transition-transform group-hover:translate-x-1"
              />
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <Divisor />
  </div>

  <!-- Por que acompanhar -->
  <section class="mx-auto max-w-7xl px-5 py-16 lg:px-8 lg:py-24">
    <div
      class="grid items-center gap-10 rounded-3xl border-2 border-tinta bg-creme p-8 shadow-zine lg:grid-cols-[1.4fr_1fr] lg:gap-14 lg:p-12"
    >
      <div>
        <p
          class="inline-flex items-center gap-2 font-display text-xs font-bold uppercase tracking-[0.2em] text-rosa-escuro"
        >
          <span class="h-px w-6 bg-rosa"></span>
          Redes
        </p>
        <h2 class="mt-3 text-3xl font-bold leading-tight sm:text-4xl">
          Por que acompanhar Eduardo Reiner?
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-tinta/80">
          Para participar de um debate político e social qualificado e
          fundamentado. Com 20 anos de experiência, ele aborda com seriedade
          temas críticos do mundo do trabalho: trabalho escravo, direitos
          trabalhistas, proteção infantil e sustentabilidade. Seu trabalho é
          focado na construção de políticas públicas reais que unem
          desenvolvimento econômico, respeito à vida e justiça social. Siga os
          perfis para se informar e integrar uma rede que busca soluções
          inteligentes e estruturais para o Brasil.
        </p>
        <Redes class="mt-7" />
      </div>
      <div class="order-first lg:order-none">
        <FotoEditorial
          src={artePopart}
          alt="Retrato artístico de Eduardo Reiner"
          cor="rosa"
          rotacao={2}
          aspecto="1 / 1"
          class="mx-auto max-w-xs"
        />
      </div>
    </div>
  </section>

  <FaixaCta />
</Base>
