  menu: { body: `<path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/>` },
  fechar: { body: `<path d="M18 6 6 18"/><path d="m6 6 12 12"/>` },
  local: {
    body: `<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>`,
  },
  email: {
    body: `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>`,
  },
  escudo: {
    body: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 11 2 2 4-4"/>`,
  },
  grafico: {
    body: `<path d="M16 7h6v6"/><path d="m22 7-8.5 8.5-5-5L2 17"/>`,
  },
  // ---- Decorativos (preenchidos) ----
  play: { fill: true, body: `<path d="M8 5v14l11-7z"/>` },
  estrela: {
    fill: true,
    body: `<path d="M12 2.6c.45 4.6 1.8 5.95 6.4 6.4-4.6.45-5.95 1.8-6.4 6.4-.45-4.6-1.8-5.95-6.4-6.4 4.6-.45 5.95-1.8 6.4-6.4Z" transform="translate(0 2.6)"/>`,
  },
};

const ico = icons[name];
const stroke = ico && !ico.fill;
const labelled = !!title;
---

{
  ico && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill={ico.fill ? "currentColor" : "none"}
      stroke={stroke ? "currentColor" : undefined}
      stroke-width={stroke ? 2 : undefined}
      stroke-linecap={stroke ? "round" : undefined}
      stroke-linejoin={stroke ? "round" : undefined}
      class={klass}
      role={labelled ? "img" : undefined}
      aria-label={labelled ? title : undefined}
      aria-hidden={labelled ? undefined : "true"}
      focusable="false"
      set:html={(labelled ? `<title>${title}</title>` : "") + ico.body}
    />
  )
}
