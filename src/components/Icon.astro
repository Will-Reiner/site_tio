---
// Sistema de ícones em SVG (sem emoji, traço consistente).
// Ícones de marca = preenchidos (Simple Icons). Ícones de UI = traço (estilo Lucide).
interface Props {
  name: string;
  size?: number;
  class?: string;
  title?: string; // se informado, o ícone vira acessível (role="img")
}
const { name, size = 24, class: klass = "", title } = Astro.props;

