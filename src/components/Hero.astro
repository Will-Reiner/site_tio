---
import { HERO } from "../data/conteudo.ts";
import { CTA } from "../data/site.ts";
import Botao from "./Botao.astro";
import FotoEditorial from "./FotoEditorial.astro";
import Redes from "./Redes.astro";
import cracha from "../assets/eduardo-cracha.jpeg";
---

<section class="relative bg-branco text-tinta">
  <!-- Textura de pontos (azul, sutil) no canto -->
  <div
    class="pontos pointer-events-none absolute right-[8%] top-24 hidden h-48 w-48 text-azul/15 lg:block"
    aria-hidden="true"
  >
  </div>

  <div
    class="mx-auto grid w-full max-w-7xl gap-8 px-5 lg:grid-cols-12 lg:items-start lg:gap-10 lg:px-8"
  >
    <!-- Texto -->
    <div class="pb-12 lg:col-span-7 lg:py-0">
      <!-- Primeira dobra: título → botões, centralizados na altura da tela,
           com margem abaixo dos botões antes do fim da tela. -->
      <div
        class="flex flex-col justify-center lg:min-h-[calc(100svh-4rem)] lg:pb-10"
      >
        <h1 class="text-5xl leading-[0.95] text-tinta sm:text-6xl lg:text-7xl">
          {HERO.titulo}<br />
          <span class="text-azul">{HERO.destaque}</span>
        </h1>
        <p
          class="mt-4 font-assinatura text-3xl leading-none text-rosa sm:text-4xl"
        >
          {HERO.assinatura}
        </p>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-tinta/80">
          {HERO.subtitulo}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Botao
            href={CTA.doar.href}
            variante="acao"
            tamanho="lg"
            iconeFim="seta-direita">{CTA.doar.label}</Botao
          >
          <Botao href="/manual/" variante="rosa" tamanho="lg" icone="escudo"
            >Acessar o Manual</Botao
          >
          <Botao href="/minha-historia/" variante="contorno" tamanho="lg"
            >Minha história</Botao
          >
        </div>
      </div>

      <!-- Abaixo da dobra: aparece ao rolar. -->
      <div class="mt-10 lg:mt-0 lg:pb-20">
        <p
          class="mb-3 font-display text-xs font-bold uppercase tracking-[0.2em] text-tinta/55"
        >
          Acompanhe
        </p>
        <Redes />
      </div>
    </div>

    <!-- Foto (foco no topo no mobile; à direita no desktop) -->
    <div
      class="order-first mx-auto flex w-full max-w-[15rem] items-center justify-center pt-6 sm:max-w-[18rem] lg:order-none lg:col-span-5 lg:min-h-[calc(100svh-4rem)] lg:max-w-[25rem] lg:pt-0"
    >
      <FotoEditorial
        src={cracha}
        alt="Eduardo Reiner com o crachá de auditor fiscal do Ministério do Trabalho"
        cor="azul"
        rotacao={2}
        aspecto="4 / 5"
        prioridade={true}
        class="mx-auto w-full max-w-sm lg:max-w-none"
      />
    </div>
  </div>
</section>
