---
import { HERO } from "../data/conteudo.ts";
import { CTA } from "../data/site.ts";
import Botao from "./Botao.astro";
import FotoEditorial from "./FotoEditorial.astro";
import Redes from "./Redes.astro";
import cracha from "../assets/eduardo-cracha.jpeg";
---

<section class="relative overflow-hidden">
  <div
    class="pontos pointer-events-none absolute -right-10 top-28 hidden h-48 w-48 text-rosa/25 lg:block"
    aria-hidden="true"
  >
  </div>
  <div
    class="mx-auto grid max-w-7xl items-center gap-12 px-5 py-12 lg:grid-cols-12 lg:gap-10 lg:px-8 lg:py-20"
  >
    <!-- Texto -->
    <div class="lg:col-span-7">
      <h1 class="text-5xl leading-[0.92] sm:text-6xl lg:text-7xl">
        {HERO.titulo}<br />
        <span class="text-rosa">{HERO.destaque}</span>
      </h1>
      <p
        class="mt-4 font-assinatura text-3xl leading-none text-rosa sm:text-4xl"
      >
        {HERO.assinatura}
      </p>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-tinta/80">
        {HERO.subtitulo}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Botao
          href={CTA.whatsapp.href}
          variante="whatsapp"
          tamanho="lg"
          icone="whatsapp">{CTA.whatsapp.label}</Botao
        >
        <Botao
          href="/propostas/"
          variante="tinta"
          tamanho="lg"
          iconeFim="seta-direita">Conhecer as propostas</Botao
        >
      </div>
      <div class="mt-10">
        <p
          class="mb-3 font-display text-xs font-bold uppercase tracking-[0.2em] text-tinta/50"
        >
          Acompanhe
        </p>
        <Redes />
      </div>
    </div>

    <!-- Foto -->
    <div class="relative mx-auto w-full max-w-sm lg:col-span-5 lg:max-w-none">
      <FotoEditorial
        src={cracha}
        alt="Eduardo Reiner com o crachá de auditor fiscal do Ministério do Trabalho"
        cor="rosa"
        rotacao={2}
        aspecto="4 / 5"
        prioridade={true}
        class="mx-auto max-w-sm"
      />
      <span
        class="absolute -left-2 bottom-6 -rotate-6 rounded-xl border-2 border-tinta bg-ambar px-4 py-2 text-center font-display text-sm font-extrabold uppercase leading-tight text-tinta shadow-[3px_3px_0_0_var(--color-tinta)]"
      >
        Auditor Fiscal<br />do Trabalho
      </span>
    </div>
  </div>
</section>
