---
interface Props {
  kicker?: string;
  titulo: string;
  alinhamento?: "esquerda" | "centro";
  class?: string;
}
const { kicker, titulo, alinhamento = "esquerda", class: klass = "" } =
  Astro.props;
const centro = alinhamento === "centro";
---

<div class:list={[centro ? "text-center" : "", klass]}>
  {
    kicker && (
      <p
        class:list={[
          "inline-flex items-center gap-2 font-display text-xs font-bold uppercase tracking-[0.2em] text-rosa-escuro",
          centro && "justify-center",
        ]}
      >
        <span class="h-px w-6 bg-rosa" />
        {kicker}
      </p>
    )
  }
  <h2 class="mt-3 text-4xl font-bold leading-[0.98] sm:text-5xl">
    {titulo}
  </h2>
  <slot />
</div>
